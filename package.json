{
  "name": "m365-mcp",
  "version": "2.0.0",
  "description": "MCP server for Claude to access Microsoft 365 (Outlook, OneDrive, Power Automate) via Microsoft Graph API",
  "main": "index.js",
  "bin": {
    "m365-mcp": "./index.js",
    "m365-mcp-auth": "./outlook-auth-server.js"
  },
  "scripts": {
    "start": "node index.js",
    "web": "node web-ui/server.js",
    "crm": "node web-ui/server.js",
    "auth-server": "node outlook-auth-server.js",
    "test-mode": "USE_TEST_MODE=true node index.js",
    "inspect": "npx @modelcontextprotocol/inspector node index.js",
    "db:migrate": "node crm/migrate.js"
  },
  "keywords": [
    "claude",
    "outlook",
    "onedrive",
    "power-automate",
    "microsoft-365",
    "mcp",
    "microsoft-graph",
    "email"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^8.2.0",
    "multer": "^2.2.0",
    "pg": "^8.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.10.2"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
