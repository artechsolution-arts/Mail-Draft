# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Then run:  docker compose up --build
# ─────────────────────────────────────────────────────────────────────────────

# Microsoft Azure App Registration
MS_CLIENT_ID=your-azure-app-client-id
MS_CLIENT_SECRET=your-azure-app-client-secret-value
MS_TENANT_ID=common

# OAuth redirect URI (must match Azure portal registration)
REDIRECT_URI=http://localhost:3000/crm/auth/callback

# Session (generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
SESSION_SECRET=replace-with-a-random-64-char-hex-string

# PostgreSQL — use DATABASE_URL or individual vars
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/outlook_crm
# PGUSER=postgres
# PGPASSWORD=yourpassword
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=outlook_crm

# Server
WEB_UI_PORT=3000
NODE_ENV=development

# Ollama (local AI draft generation)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
